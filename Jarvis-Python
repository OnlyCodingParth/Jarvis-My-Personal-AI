# ── FUNCTION EXECUTOR ────────────────────────────────────────
def execute_function(func_name, func_args):
    if func_name == "open_application":       return open_app_smart(func_args.get("app_name", ""))
    if func_name == "open_folder":            return open_folder(func_args.get("folder_name", ""))
    if func_name == "search_service":         return smart_search(func_args.get("query", ""), func_args.get("service"))
    if func_name == "youtube_search":
        q = func_args.get("query", "")
        webbrowser.open(SEARCH_URLS["youtube"] + q.replace(" ", "+")); session_ctx["last_service"] = "youtube"
        return f"Searching '{q}' on YouTube!"
    if func_name == "get_time":
        n = datetime.datetime.now(); return f"It's {n.strftime('%I:%M %p')}, {n.strftime('%A, %d %B %Y')}."
    if func_name == "send_whatsapp":
        c, m = func_args.get("contact_name", ""), func_args.get("message", "")
        if c and m: return _do_send_wa(c, m)
        session_ctx["wa_state"] = "ask_contact" if not c else "ask_message"
        if c: session_ctx["wa_contact"] = c
        return "Who should I message?" if not c else f"What would you like to say to {c}?"
    if func_name == "start_whatsapp_flow":
        c, m = func_args.get("contact_name", ""), func_args.get("message", "")
        if c and m:
            session_ctx.update({"wa_state": "confirm", "wa_contact": c, "wa_message": m})
            return f'Confirm: send "{m}" to {c}? Yes or No?'
        session_ctx["wa_state"] = "ask_contact" if not c else "ask_message"
        if c: session_ctx["wa_contact"] = c
        return "Who should I message?" if not c else f"What would you like to say to {c}?"
    if func_name == "control_volume":
        a = func_args.get("action", "get")
        if a == "set":  return set_volume(func_args.get("level", 50))
        if a == "up":   return change_volume("up",   func_args.get("amount", 10))
        if a == "down": return change_volume("down", func_args.get("amount", 10))
        if a == "mute": return mute_volume()
        v = get_volume(); return f"Volume is at {v}%." if v >= 0 else "Could not read volume."
    if func_name == "control_brightness":
        return set_brightness(func_args.get("level", 70)) if func_args.get("action") == "set" else get_brightness()
    if func_name == "get_battery":         return get_battery()
    if func_name == "power_control":
        a = func_args.get("action", ""); d = func_args.get("delay", 0)
        if a == "shutdown": return shutdown_laptop(d)
        if a == "restart":  return restart_laptop(d)
        if a == "sleep":    return sleep_laptop()
        if a == "lock":     return lock_screen()
    if func_name == "control_wifi":
        a = func_args.get("action", "status")
        return wifi_on() if a == "on" else wifi_off() if a == "off" else wifi_status()
    if func_name == "control_bluetooth":
        return bluetooth_on() if func_args.get("action", "on") == "on" else bluetooth_off()
    if func_name == "take_screenshot":     return take_screenshot()
    if func_name == "close_application":   return close_app(func_args.get("app_name", ""))
    if func_name == "get_system_info":     return get_system_info()
    if func_name == "list_running_apps":   return list_running_apps()
    if func_name == "remember_preference":
        k, v = func_args.get("key", ""), func_args.get("value", "")
        prefs[k] = v; save_prefs(prefs); return f"Noted: {k} = {v}."
    return "I didn't understand that command."

# ── ASK JARVIS ───────────────────────────────────────────────
def ask_jarvis(user_text: str) -> str:
    global conversation_history
    t = user_text.lower().strip()

    # Stateful flow handlers (intercept before AI)
    if session_ctx["wa_state"]:
        reply = handle_whatsapp_flow(user_text)
        if reply:
            conversation_history += [{"role": "user", "content": user_text}, {"role": "assistant", "content": reply}]
            return reply

    # YouTube search shortcut
    if re.search(r"\byoutube\b", t) and re.search(r"\bsearch\b|\bplay\b|\bfind\b", t):
        q = extract_search_query(t.replace("youtube", "").strip())
        if q:
            webbrowser.open(SEARCH_URLS["youtube"] + q.replace(" ", "+")); session_ctx["last_service"] = "youtube"
            reply = f"Searching '{q}' on YouTube!"
        else:
            session_ctx["yt_state"] = "ask_query"
            reply = "What should I search on YouTube?"
        conversation_history += [{"role": "user", "content": user_text}, {"role": "assistant", "content": reply}]
        return reply

    if session_ctx["yt_state"] == "ask_query":
        session_ctx["yt_state"] = None; session_ctx["last_service"] = "youtube"
        webbrowser.open(SEARCH_URLS["youtube"] + user_text.replace(" ", "+"))
        reply = f"Searching '{user_text}' on YouTube!"
        conversation_history += [{"role": "user", "content": user_text}, {"role": "assistant", "content": reply}]
        return reply

    # AI path
    name      = prefs.get("name", "Boss")
    sysprompt = f"""You are Jarvis, a smart personal AI assistant for Windows. User: {name}. Speak in clear English.
PERSONALITY: warm, witty, professional. Max 2 sentence replies. ALWAYS use function calls.

RULES:
- open <app>         → open_application (prefer desktop app, fallback browser)
- open <folder>      → open_folder (NEVER browser)
- search youtube     → youtube_search
- whatsapp message   → start_whatsapp_flow
- volume/brightness/battery/power/wifi/bluetooth/screenshot/sysinfo → correct function
Context: {session_ctx.get('last_service') or 'none'}"""

    conversation_history.append({"role": "user", "content": user_text})
    if len(conversation_history) > MAX_HISTORY * 2:
        conversation_history = conversation_history[-(MAX_HISTORY * 2):]

    if not ai_client:
        r = handle_basic_commands(user_text); conversation_history.append({"role": "assistant", "content": r}); return r

    try:
        msgs = [{"role": "system", "content": sysprompt}] + conversation_history
        resp = ai_client.chat.completions.create(
            model=GROQ_MODEL, messages=msgs,
            tools=[{"type": "function", "function": f} for f in GROQ_FUNCTIONS],
            tool_choice="auto", max_tokens=400)
        msg = resp.choices[0].message
        if msg.tool_calls:
            tc = msg.tool_calls[0]
            fn, fa = tc.function.name, json.loads(tc.function.arguments)
            print(f"⚙️  {fn}({fa})")
            result = execute_function(fn, fa)
            conversation_history += [{"role": "assistant", "content": None, "tool_calls": [tc.model_dump()]},
                                      {"role": "tool", "tool_call_id": tc.id, "content": result}]
            return result
        reply = (msg.content or "").strip() or "I didn't quite catch that."
        conversation_history.append({"role": "assistant", "content": reply}); return reply
    except Exception as e:
        print(f"❌ Groq: {e}")
        fb = handle_basic_commands(user_text); conversation_history.append({"role": "assistant", "content": fb}); return fb

# ── BASIC FALLBACK ───────────────────────────────────────────
def handle_basic_commands(text):
    t = text.lower()
    if any(w in t for w in ["time", "date", "what time", "what day"]):
        n = datetime.datetime.now(); return f"It's {n.strftime('%I:%M %p')}, {n.strftime('%A, %d %B %Y')}."
    if any(w in t for w in ["battery", "charge"]): return get_battery()
    if any(w in t for w in ["volume", "sound"]):
        nums = re.findall(r'\d+', t)
        if any(w in t for w in ["increase", "up", "louder", "raise"]): return change_volume("up",   int(nums[0]) if nums else 10)
        if any(w in t for w in ["decrease", "down", "lower", "reduce"]): return change_volume("down", int(nums[0]) if nums else 10)
        if any(w in t for w in ["mute", "silence", "quiet"]): return mute_volume()
        if nums: return set_volume(int(nums[0]))
        v = get_volume(); return f"Volume is at {v}%." if v >= 0 else "Could not read volume."
    if any(w in t for w in ["brightness"]):
        nums = re.findall(r'\d+', t); return set_brightness(int(nums[0])) if nums else get_brightness()
    if any(w in t for w in ["shutdown", "turn off"]):  return shutdown_laptop()
    if any(w in t for w in ["restart", "reboot"]):     return restart_laptop()
    if any(w in t for w in ["sleep", "hibernate"]):    return sleep_laptop()
    if any(w in t for w in ["lock", "screen lock"]):   return lock_screen()
    if "wifi" in t or "wi-fi" in t:
        if any(w in t for w in ["on", "enable"]): return wifi_on()
        if any(w in t for w in ["off", "disable"]): return wifi_off()
        return wifi_status()
    if "bluetooth" in t: return bluetooth_on() if any(w in t for w in ["on", "enable"]) else bluetooth_off()
    if any(w in t for w in ["screenshot", "capture screen"]): return take_screenshot()
    if any(w in t for w in ["system info", "cpu", "ram", "disk"]): return get_system_info()
    if any(w in t for w in ["running apps", "list apps", "what's open"]): return list_running_apps()
    if any(w in t for w in ["close", "kill", "quit"]):
        for app in ["chrome", "firefox", "notepad", "vlc", "spotify", "whatsapp", "teams", "word", "excel", "edge"]:
            if app in t: return close_app(app)
    # Folders first
    for folder, path in FOLDERS.items():
        if folder in t and os.path.exists(path): os.startfile(path); return f"{folder} folder opened!"
    # YouTube
    if "youtube" in t:
        q = extract_search_query(t)
        if q: webbrowser.open(SEARCH_URLS["youtube"] + q.replace(" ", "+")); return f"YouTube search: '{q}'"
        webbrowser.open(WEBSITES["youtube"]); return "YouTube opened!"
    # Search
    if any(w in t for w in ["search", "find", "look up"]):
        svc = detect_search_service(t); q = extract_search_query(t)
        if q: return smart_search(q, svc)
        return "What should I search for?"
    # Sites
    for site, url in WEBSITES.items():
        if site in t: webbrowser.open(url); session_ctx["last_service"] = site; return f"{site} opened!"
    # Apps
    for app in APP_PATHS:
        if app in t: return open_app_smart(app)
    if any(w in t for w in ["stop", "bye", "exit", "goodbye"]): return "Goodbye, sir!"
    return "I didn't understand that. Try: increase volume, battery status, take a screenshot, open YouTube, open downloads folder."

# ── VOICE SESSION ────────────────────────────────────────────
def run_active_session():
    speak_listening(); misses = 0
    while True:
        cmd = listen_for_command(timeout=9)
        if not cmd:
            misses += 1
            if misses == 1: speak("Still here.")
            elif misses == 2: speak("I'm listening, sir.")
            elif misses >= 3: speak("Going to sleep. Say Jarvis to wake me."); return
            continue
        misses = 0
        if is_full_exit(cmd): speak("Shutting down. Goodbye!"); raise SystemExit(0)
        if is_session_end(cmd): speak("Sleep mode. Call me anytime."); return
        print(f"🔄 {cmd}")
        try:
            resp = ask_jarvis(cmd)
        except Exception as e:
            print(f"❌ {e}"); speak("An error occurred. Please try again."); continue
        if resp: speak(resp)
        else: speak_done()
        time.sleep(0.3); speak_waiting()

