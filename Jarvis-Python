def extract_search_query(text):
    REMOVE = ["search on youtube", "search in youtube", "search youtube for", "search on google",
              "search google for", "search on amazon", "search amazon for", "search on spotify",
              "search on netflix", "search on flipkart", "search for", "search", "find", "look up",
              "on youtube", "on google", "on amazon", "in youtube", "in google"]
    q = text
    for ph in REMOVE: q = q.replace(ph, "").strip()
    return q.strip()

# ── STATEFUL WHATSAPP ────────────────────────────────────────
def _reset_wa():
    session_ctx.update({"wa_state": None, "wa_contact": None, "wa_message": None})

def handle_whatsapp_flow(text):
    ctx = session_ctx
    t   = text.lower().strip()
    if ctx["wa_state"] is None: return None

    if ctx["wa_state"] == "ask_contact":
        ctx["wa_contact"] = text.strip(); ctx["wa_state"] = "ask_message"
        return f"Got it — what would you like to say to {ctx['wa_contact']}?"

    if ctx["wa_state"] == "ask_message":
        ctx["wa_message"] = text.strip(); ctx["wa_state"] = "confirm"
        return f'Confirm: send "{ctx["wa_message"]}" to {ctx["wa_contact"]}? Yes or No?'

    if ctx["wa_state"] == "confirm":
        if any(w in t for w in ["yes", "ok", "sure", "confirm", "send", "yeah"]):
            c, m = ctx["wa_contact"], ctx["wa_message"]
            _reset_wa(); return _do_send_wa(c, m)
        _reset_wa(); return "Message cancelled."

    _reset_wa(); return None

def _do_send_wa(contact_name, message):
    phone = prefs.get("whatsapp_contacts", {}).get(contact_name.lower())
    if not phone:
        return f"No number found for '{contact_name}'. Please add it to whatsapp_contacts in {PREFS_FILE}."
    try:
        n = datetime.datetime.now()
        h, m = n.hour, n.minute + 1
        if m >= 60: m, h = 0, (h + 1) % 24
        pywhatkit.sendwhatmsg(phone, message, h, m, wait_time=20, tab_close=True, close_time=5)
        return f"Message sent to {contact_name}!"
    except Exception as e:
        print(f"❌ pywhatkit: {e}"); return "Message failed. Is WhatsApp Web open and logged in?"

