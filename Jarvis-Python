tts_engine = pyttsx3.init()

# Voice priority: Microsoft Aria (neural) > Zira > Jenny > Eva > any English female
VOICE_SCORE = {
    "aria"   : 120,   # Microsoft Aria Neural — closest to "Era"
    "eva"    : 115,   # Some systems have Eva
    "jenny"  : 110,
    "zira"   : 100,
    "hazel"  : 90,
    "female" : 80,
    "woman"  : 80,
    "neural" : 75,
    "english": 50,
    "en"     : 40,
}

def _score_voice(v):
    name_lower = v.name.lower()
    lang_lower = (v.languages[0].lower() if v.languages else "")
    combo = name_lower + " " + lang_lower
    # Prefer female voices — skip voices with male-only names
    if any(m in name_lower for m in ["david", "mark", "george", "james", "guy", "richard"]):
        return -1
    return max((pts for kw, pts in VOICE_SCORE.items() if kw in combo), default=0)

def configure_voice():
    voices = tts_engine.getProperty("voices")
    if not voices: return
    best = sorted(voices, key=_score_voice, reverse=True)[0]
    tts_engine.setProperty("voice", best.id)
    # Era-style: clear, bright, slightly faster than default, confident
    tts_engine.setProperty("rate",   158)   # slightly brisk, natural
    tts_engine.setProperty("volume", 0.97)
    print(f"✅ Voice: {best.name}")

configure_voice()

