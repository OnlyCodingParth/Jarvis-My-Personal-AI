def listen_for_wake_word():
    print('👂 Sleeping... say "Jarvis" to wake.')
    dots = 0
    while True:
        with sr.Microphone() as src:
            recognizer.adjust_for_ambient_noise(src, duration=0.3)
            try: audio = recognizer.listen(src, timeout=4, phrase_time_limit=4)
            except sr.WaitTimeoutError:
                dots += 1
                if dots % 4 == 0: print("   ... still listening")
                continue
        try:
            heard = recognizer.recognize_google(audio, language="en-IN").lower()
            if any(w in heard for w in WAKE_WORDS): print("✅ Wake word!\n"); return True
        except: continue

def listen_for_command(timeout=8):
