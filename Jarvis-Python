# ── APP LAUNCHER ─────────────────────────────────────────────
def open_app_smart(app_name):
    al = app_name.lower().strip()
    session_ctx["last_service"] = al

    # 1) Known exe
    exe = APP_PATHS.get(al, "")
    if exe:
        matches = glob.glob(os.path.expandvars(exe))
        path    = matches[0] if matches else os.path.expandvars(exe)
        if os.path.exists(path):
            try: subprocess.Popen(path); return f"{app_name} opened! (desktop app)"
            except Exception as e: print(f"⚠️ {e}")

    # 2) Store URI
    if al in STORE_APPS:
        try: os.startfile(STORE_APPS[al]); return f"{app_name} launched! (store)"
        except: pass

    # 3) Shortcut
    for folder in [os.path.expanduser("~/Desktop"),
                   os.path.expanduser("~/AppData/Roaming/Microsoft/Windows/Start Menu/Programs"),
                   r"C:\ProgramData\Microsoft\Windows\Start Menu\Programs"]:
        ms = glob.glob(os.path.join(folder, "**", f"*{al}*.lnk"), recursive=True)
        if ms:
            try: os.startfile(ms[0]); return f"{app_name} opened via shortcut!"
            except: pass

    # 4) Browser fallback
    url = WEBSITES.get(al)
    if url:
        webbrowser.open(url)
        return f"{app_name} opened in browser (desktop app not found)."

    return f"Could not find '{app_name}'. Please add it to APP_PATHS."

def open_folder(folder_name):
    fl   = folder_name.lower().strip()
    path = FOLDERS.get(fl)
    if path and os.path.exists(path):
        os.startfile(path); return f"{folder_name} folder opened!"
    for k, p in FOLDERS.items():
        if (k in fl or fl in k) and os.path.exists(p):
            os.startfile(p); return f"{k} folder opened!"
    return f"Could not find folder '{folder_name}'."

